<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Restrict cleartext traffic only to local network hosts and private IP blocks (including Tailscale CGNAT) -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Localhost / Loopback -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>

        <!-- Private IP Subnets (IPv4 RFC 1918) -->
        <!-- Class A Private Network: 10.0.0.0 - 10.255.255.255 -->
        <domain includeSubdomains="true">10.in-addr.arpa</domain>
        <!-- Class B Private Network: 172.16.0.0 - 172.31.255.255 -->
        <!-- Class C Private Network: 192.168.0.0 - 192.168.255.255 -->
        <domain includeSubdomains="true">168.192.in-addr.arpa</domain>

        <!-- Tailscale CGNAT IP Subnet: 100.64.0.0 - 100.127.255.255 -->
        <domain includeSubdomains="true">64.100.in-addr.arpa</domain>
        <domain includeSubdomains="true">65.100.in-addr.arpa</domain>
        <domain includeSubdomains="true">66.100.in-addr.arpa</domain>
